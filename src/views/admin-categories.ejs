<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Smart Booking</title>
    <link rel="stylesheet" href="/styles/dashboard.css" />
    <link rel="stylesheet" href="/styles/admin.css" />
    <link rel="stylesheet" href="/styles/admin-categories.css" />
</head>
<body class="admin-categories-body">
<div class="dashboard-page">
<div class="dashboard">

    <%- include('partials/dashboard-sidebar', { role, activePage }) %>

    <main class="dashboard-main">
        <%- include('partials/dashboard-topbar', {
            breadcrumbMain: 'Home',
            breadcrumbSub: 'Categories',
            firstName,
            role,
            searchPlaceholder: 'Search users, services, appointments...',
            showNotification: false
        }) %>

        <div class="dashboard-content">

            <% if (message) { %>
            <div class="admin-feedback <%= messageType %>">
                <span><%= message %></span>
                <button class="ac-feedback-close" type="button" onclick="this.parentElement.remove()">&#x2715;</button>
            </div>
            <% } %>

            <!-- Page Header -->
            <div class="ac-page-header">
                <div>
                    <h2 class="ac-page-title">Categories</h2>
                    <p class="ac-page-subtitle">Manage all service categories in your booking system</p>
                </div>
                <button class="ac-btn-add" type="button" id="openAddModal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2z"/>
                    </svg>
                    Add New Category
                </button>
            </div>

            <!-- Table Card -->
            <div class="ac-card">
                <!-- Toolbar -->
                <div class="ac-toolbar">
                    <div class="ac-show-entries">
                        <span>Show</span>
                        <select id="acEntriesSelect" class="ac-entries-select">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                        <span>entries</span>
                    </div>
                    <div class="ac-search-wrap">
                        <svg class="ac-search-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input type="text" id="acSearchInput" class="ac-search-input" placeholder="Search categories..." />
                    </div>
                </div>

                <!-- Table -->
                <div class="ac-table-outer">
                    <table class="ac-table">
                        <colgroup>
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                        </colgroup>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Category</th>
                                <th>Description</th>
                                <th>Services</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="acTableBody">
                            <!-- Populated by admin-categories.js -->
                        </tbody>
                    </table>
                </div>

                <!-- Footer -->
                <div class="ac-table-footer">
                    <span id="acShowingText" class="ac-showing">Showing 0 to 0 of 0 entries</span>
                    <div class="ac-pagination" id="acPagination"></div>
                </div>
            </div>

        </div><!-- /.dashboard-content -->
    </main>

</div>
</div>

<!-- ADD CATEGORY MODAL -->
<div class="ac-overlay" id="addModalOverlay">
    <div class="ac-modal">
        <div class="ac-modal-head">
            <h3 class="ac-modal-title">Add New Category</h3>
            <button class="ac-modal-close" type="button" data-close="addModalOverlay">&#x2715;</button>
        </div>
        <form class="ac-form" method="POST" action="/views/admin-categories/create">
            <div class="ac-form-group">
                <label class="ac-label">Category Name <span class="ac-req">*</span></label>
                <input type="text" name="category_name" class="ac-input" placeholder="e.g. Hair Services" required />
            </div>
            <div class="ac-form-group">
                <label class="ac-label">Description</label>
                <textarea name="category_description" class="ac-input ac-textarea" placeholder="Short description of this category" rows="3"></textarea>
            </div>
            <div class="ac-form-group">
                <label class="ac-label">Status</label>
                <select name="category_is_active" class="ac-input">
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
            <div class="ac-form-actions">
                <button type="button" class="ac-btn-cancel" data-close="addModalOverlay">Cancel</button>
                <button type="submit" class="ac-btn-submit">Create Category</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT CATEGORY MODAL -->
<div class="ac-overlay" id="editModalOverlay">
    <div class="ac-modal">
        <div class="ac-modal-head">
            <h3 class="ac-modal-title">Edit Category</h3>
            <button class="ac-modal-close" type="button" data-close="editModalOverlay">&#x2715;</button>
        </div>
        <form class="ac-form" method="POST" id="editCategoryForm" action="#">
            <div class="ac-form-group">
                <label class="ac-label">Category Name <span class="ac-req">*</span></label>
                <input type="text" name="category_name" id="editCatName" class="ac-input" required />
            </div>
            <div class="ac-form-group">
                <label class="ac-label">Description</label>
                <textarea name="category_description" id="editCatDesc" class="ac-input ac-textarea" rows="3"></textarea>
            </div>
            <div class="ac-form-group">
                <label class="ac-label">Status</label>
                <select name="category_is_active" id="editCatStatus" class="ac-input">
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
            <div class="ac-form-actions">
                <button type="button" class="ac-btn-cancel" data-close="editModalOverlay">Cancel</button>
                <button type="submit" class="ac-btn-submit">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- DELETE CONFIRM MODAL -->
<div class="ac-overlay" id="deleteModalOverlay">
    <div class="ac-modal ac-modal-sm">
        <div class="ac-modal-head">
            <h3 class="ac-modal-title">Delete Category</h3>
            <button class="ac-modal-close" type="button" data-close="deleteModalOverlay">&#x2715;</button>
        </div>
        <div class="ac-modal-body">
            <p class="ac-del-msg">Are you sure you want to delete <strong id="deleteCatName">this category</strong>? This action cannot be undone.</p>
        </div>
        <form method="POST" id="deleteCategoryForm" action="#">
            <div class="ac-form-actions">
                <button type="button" class="ac-btn-cancel" data-close="deleteModalOverlay">Cancel</button>
                <button type="submit" class="ac-btn-delete">Delete</button>
            </div>
        </form>
    </div>
</div>

<script>
    var ALL_CATEGORIES = <%- JSON.stringify(categories || []) %>;
</script>
<script src="/scripts/admin/admin-categories.js"></script>
</body>
</html>
