<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof title !== "undefined" ? title : "Login" %></title>
    <link rel="stylesheet" href="/styles/login.css" />
</head>

<body>
    <main class="page">
        <section class="auth-card">
            <div class="photo-side">
                <img src="/images/login.png" alt="Smart booking reception" />

                <div class="info-box">
                    <div class="info-icon">📅</div>
                    <div>
                        <strong>Your time matters.</strong>
                        <p>We make booking simple, so you can focus on what matters most.</p>
                    </div>
                </div>
            </div>

            <div class="form-side">
                <div class="form-content">
                    <div class="top-icon">📅</div>

                    <h2 class="brand-title">Smart Booking System</h2>
                    <p class="brand-subtitle">Clinic / Salon / Advisor</p>

                    <h1>Welcome Back</h1>
                    <p class="description">Manage your appointments and services with ease.</p>

                    <% if (typeof message !== "undefined" && message) { %>
                        <div class="message <%= messageType === 'error' ? 'error' : 'success' %>">
                            <%= message %>
                        </div>
                    <% } %>

                    <form action="/views/login" method="POST">
                        <div class="field">
                            <label for="user_email">Email</label>
                            <div class="input-box">
                                <span class="input-icon">✉️</span>
                                <input
                                    type="email"
                                    id="user_email"
                                    name="user_email"
                                    placeholder="Enter your email"
                                    autocomplete="email"
                                    required
                                />
                            </div>
                        </div>

                        <div class="field">
                            <label for="user_password">Password</label>
                            <div class="input-box">
                                <span class="input-icon">🔒</span>

                                <input
                                    type="password"
                                    id="user_password"
                                    name="user_password"
                                    placeholder="Enter your password"
                                    autocomplete="current-password"
                                    required
                                />

                                <!-- NEW: show/hide password button inside input box -->
                                <button
                                    type="button"
                                    class="password-toggle"
                                    id="togglePassword"
                                    aria-label="Show password"
                                >
                                    👁️
                                </button>
                            </div>
                        </div>

                        <button class="login-button" type="submit">
                            Login →
                        </button>
                    </form>

                    <p class="register-text">
                        Don't have an account?
                        <a href="/views/register">Register</a>
                    </p>

                    <div class="bottom-divider">
                        <span class="heart">♡</span>
                    </div>

                    <p class="secure-note">
                        Built to help you deliver exceptional care and seamless appointment experiences.
                    </p>
                </div>
            </div>
        </section>
    </main>

    <script src="/scripts/auth/login.js"></script>
</body>
</html>