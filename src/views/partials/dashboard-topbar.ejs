<%
    function capitalizeTopbarName(value) {
        if (!value) return "User";

        const text = String(value).trim();

        if (!text) return "User";

        return text.charAt(0).toUpperCase() + text.slice(1).toLowerCase();
    }

    function formatTopbarFirstName(value) {
        if (!value) return "User";

        let text = String(value).trim();

        if (!text) return "User";

        if (text.includes("@")) {
            text = text.split("@")[0];
        }

        text = text
            .replace(/[0-9]/g, "")
            .replace(/[._-]+/g, " ")
            .trim();

        const parts = text.split(/\s+/).filter(Boolean);

        if (parts.length > 1) {
            return capitalizeTopbarName(parts[0]);
        }

        let singleValue = parts[0] || text;
        const lowerValue = singleValue.toLowerCase();

        const knownFirstNames = [
            "antonio",
            "john",
            "jane",
            "maria",
            "marie",
            "mohammad",
            "mohammed",
            "ahmad",
            "ali",
            "hassan",
            "hussein",
            "george",
            "elie",
            "joe",
            "charbel",
            "mike",
            "sarah",
            "priya",
        ];

        const matchedName = knownFirstNames.find(function(name) {
            return lowerValue.startsWith(name);
        });

        if (matchedName) {
            singleValue = matchedName;
        }

        return capitalizeTopbarName(singleValue);
    }

    const safeBreadcrumbMain =
        typeof breadcrumbMain !== "undefined" && breadcrumbMain
            ? breadcrumbMain
            : "Home";

    const safeBreadcrumbMiddle =
        typeof breadcrumbMiddle !== "undefined" && breadcrumbMiddle
            ? breadcrumbMiddle
            : null;

    const safeBreadcrumbSub =
        typeof breadcrumbSub !== "undefined" && breadcrumbSub
            ? breadcrumbSub
            : "Dashboard";

    const rawFirstName =
        typeof firstName !== "undefined" && firstName
            ? firstName
            : "User";

    const safeFirstName = formatTopbarFirstName(rawFirstName);

    const safeRole =
        typeof role !== "undefined" && role
            ? role
            : "client";

    const roleLabels = {
        admin: "Administrator",
        staff: "Staff Member",
        client: "Client",
    };

    const safeRoleLabel = roleLabels[safeRole] || "User";

    const defaultSearchPlaceholder =
        safeRole === "admin"
            ? "Search services, categories, users..."
            : safeRole === "staff"
                ? "Search appointments, clients, services..."
                : "Search services, categories...";

    const safeSearchPlaceholder =
        typeof searchPlaceholder !== "undefined" && searchPlaceholder
            ? searchPlaceholder
            : defaultSearchPlaceholder;

    const safeNotificationCount =
        typeof notificationCount !== "undefined" && notificationCount
            ? notificationCount
            : 0;

    const shouldShowNotification =
        typeof showNotification !== "undefined"
            ? showNotification
            : safeRole === "admin" || safeRole === "staff";

    const userInitial = safeFirstName.charAt(0).toUpperCase();
%>

<header class="dashboard-topbar">
    <div class="breadcrumb">
        <span class="active-crumb"><%= safeBreadcrumbMain %></span>

        <% if (safeBreadcrumbMiddle) { %>
            <span>/</span>
            <span class="active-crumb"><%= safeBreadcrumbMiddle %></span>
        <% } %>

        <span>/</span>
        <span><%= safeBreadcrumbSub %></span>
    </div>

    <div class="topbar-right">
        <form class="search-box" action="#" method="GET" id="dashboardSearchForm">
            <span class="search-icon">🔍</span>

            <input
                id="dashboardSearchInput"
                type="text"
                name="search"
                placeholder="<%= safeSearchPlaceholder %>"
                autocomplete="off"
            />
        </form>

        <% if (shouldShowNotification) { %>
            <button class="notification-button" type="button" aria-label="Notifications">
                <span class="notification-icon">🔔</span>

                <% if (safeNotificationCount > 0) { %>
                    <span class="notification-badge">
                        <%= safeNotificationCount %>
                    </span>
                <% } %>
            </button>
        <% } %>

        <div class="user-box">
            <div class="avatar">
                <span><%= userInitial %></span>
            </div>

            <div class="user-info">
                <strong>Hello, <%= safeFirstName %></strong>
                <span><%= safeRoleLabel %></span>
            </div>

            <span class="user-chevron">⌄</span>
        </div>
    </div>
</header>