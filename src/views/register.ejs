<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof title !== "undefined" ? title : "Register" %></title>

    <style>
        :root {
            --primary: #0f8f8c;
            --primary-dark: #087674;
            --primary-soft: #e6fffb;
            --orange: #f59e0b;
            --text: #1f2937;
            --muted: #64748b;
            --border: #e5e7eb;
            --danger-bg: #fef2f2;
            --danger: #991b1b;
            --success-bg: #ecfdf5;
            --success: #065f46;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            height: 100vh;
            overflow: hidden;
            font-family: "Segoe UI", Arial, sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at 8% 32%, rgba(178, 242, 245, 0.75), transparent 26%),
                radial-gradient(circle at 94% 42%, rgba(255, 237, 213, 0.95), transparent 30%),
                linear-gradient(135deg, #f8ffff 0%, #ffffff 48%, #fff7ed 100%);
        }

        .page {
            height: 100vh;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 14px 24px;
        }

        .page::before {
            content: "";
            position: absolute;
            left: -60px;
            top: 170px;
            width: 220px;
            height: 220px;
            border: 9px solid rgba(15, 143, 140, 0.08);
            border-radius: 50%;
        }

        .page::after {
            content: "";
            position: absolute;
            right: 120px;
            top: 250px;
            width: 100px;
            height: 100px;
            border: 8px solid rgba(255, 255, 255, 0.85);
            border-radius: 50%;
        }

        .auth-card {
            width: 100%;
            max-width: 1280px;
            height: calc(100vh - 28px);
            display: grid;
            grid-template-columns: 1fr 1fr;
            background: rgba(255, 255, 255, 0.88);
            border-radius: 28px;
            box-shadow: 0 28px 90px rgba(15, 23, 42, 0.13);
            overflow: hidden;
            position: relative;
            z-index: 2;
        }

        .photo-side {
            position: relative;
            height: 100%;
            overflow: hidden;
        }

        .photo-side img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            display: block;
        }

        .photo-side::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(
                90deg,
                rgba(255, 255, 255, 0.02),
                rgba(255, 255, 255, 0.16)
            );
        }

        .info-box {
            position: absolute;
            left: 28px;
            bottom: 78px;
            width: 390px;
            max-width: calc(100% - 56px);
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 15px 18px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.82);
            backdrop-filter: blur(14px);
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
            z-index: 3;
        }

        .info-icon {
            width: 44px;
            height: 44px;
            flex: 0 0 44px;
            display: grid;
            place-items: center;
            border-radius: 14px;
            background: var(--primary);
            color: white;
            font-size: 1.1rem;
        }

        .info-box strong {
            display: block;
            margin-bottom: 4px;
            font-size: 0.98rem;
            color: #172033;
        }

        .info-box p {
            margin: 0;
            color: #475569;
            line-height: 1.35;
            font-size: 0.88rem;
        }

        .form-side {
            height: 100%;
            padding: 0 60px;
            background: rgba(255, 255, 255, 0.94);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .form-content {
            width: 100%;
            max-width: 430px;
            text-align: center;
            transform: translateY(-28px) scale(0.76);
            transform-origin: center;
        }

        .top-icon {
            width: 38px;
            height: 38px;
            margin: 0 auto 5px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            background: var(--primary-soft);
            color: var(--primary);
            font-size: 1.05rem;
        }

        .brand-title {
            margin: 0;
            color: var(--primary);
            font-family: Georgia, "Times New Roman", serif;
            font-size: 1.5rem;
            font-weight: 800;
        }

        .brand-subtitle {
            margin: 2px 0 0;
            color: var(--muted);
            font-size: 0.84rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .brand-subtitle::before,
        .brand-subtitle::after {
            content: "";
            width: 58px;
            height: 1px;
            background: #d7dce2;
        }

        h1 {
            margin: 10px 0 4px;
            font-family: Georgia, "Times New Roman", serif;
            font-size: 2.25rem;
            line-height: 1.05;
            letter-spacing: -0.04em;
            color: #172033;
        }

        .description {
            margin: 0 0 8px;
            color: var(--muted);
            font-size: 0.92rem;
            line-height: 1.3;
        }

        .message {
            margin-bottom: 8px;
            padding: 8px 12px;
            border-radius: 12px;
            font-weight: 700;
            text-align: left;
            font-size: 0.88rem;
        }

        .message.success {
            background: var(--success-bg);
            color: var(--success);
        }

        .message.error {
            background: var(--danger-bg);
            color: var(--danger);
        }

        form {
            text-align: left;
        }

        .field {
            margin-bottom: 6px;
        }

        label {
            display: block;
            margin-bottom: 3px;
            font-weight: 800;
            color: #111827;
            font-size: 0.9rem;
        }

        .input-box {
            height: 39px;
            width: 100%;
            display: flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #d8dee8;
            border-radius: 12px;
            background: white;
            padding: 0 13px;
            transition: 0.2s ease;
        }

        .input-box:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(15, 143, 140, 0.12);
        }

        .input-icon {
            color: #7b8794;
            font-size: 0.92rem;
            flex: 0 0 auto;
        }

        input[type="email"],
        input[type="password"],
        input[type="text"],
        input[type="tel"] {
            width: 100%;
            border: 0;
            outline: 0;
            background: transparent;
            font-family: inherit;
            font-size: 0.92rem;
            color: var(--text);
        }

        input::placeholder {
            color: #94a3b8;
        }

        .password-toggle {
            border: 0;
            outline: 0;
            background: transparent;
            color: #64748b;
            font-size: 0.98rem;
            cursor: pointer;
            padding: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s ease;
            flex: 0 0 auto;
        }

        .password-toggle:hover {
            color: var(--primary);
            transform: scale(1.08);
        }

        .register-button {
            width: 100%;
            height: 42px;
            border: 0;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            font-family: inherit;
            font-size: 0.96rem;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 16px 30px rgba(15, 143, 140, 0.22);
            transition: 0.2s ease;
            margin-top: 5px;
        }

        .register-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 38px rgba(15, 143, 140, 0.28);
        }

        .login-text {
            margin: 8px 0 7px;
            color: var(--muted);
            text-align: center;
            font-size: 0.9rem;
        }

        a {
            color: var(--orange);
            font-weight: 800;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .bottom-divider {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 6px;
        }

        .bottom-divider::before,
        .bottom-divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .heart {
            width: 25px;
            height: 25px;
            display: grid;
            place-items: center;
            border-radius: 50%;
            background: #fff7ed;
            color: var(--orange);
            border: 1px solid #ffedd5;
            font-size: 0.78rem;
        }

        .secure-note {
            max-width: 330px;
            margin: 0 auto;
            color: var(--muted);
            line-height: 1.25;
            font-size: 0.8rem;
        }

        @media (max-width: 1000px) {
            body {
                height: auto;
                overflow-y: auto;
            }

            .page {
                height: auto;
                min-height: 100vh;
                padding: 24px;
            }

            .auth-card {
                height: auto;
                max-width: 560px;
                grid-template-columns: 1fr;
            }

            .photo-side {
                display: none;
            }

            .form-side {
                padding: 36px 28px;
            }

            .form-content {
                transform: none;
            }
        }

        @media (max-width: 520px) {
            .page {
                padding: 18px 14px;
            }

            .form-side {
                padding: 30px 20px;
            }

            h1 {
                font-size: 2.05rem;
            }

            .brand-title {
                font-size: 1.28rem;
            }

            .brand-subtitle::before,
            .brand-subtitle::after {
                width: 34px;
            }
        }
    </style>
</head>

<body>
    <main class="page">
        <section class="auth-card">
            <div class="photo-side">
                <img src="/images/login.png" alt="Smart booking registration" />

                <div class="info-box">
                    <div class="info-icon">📅</div>
                    <div>
                        <strong>Get started today.</strong>
                        <p>Create your account to enjoy fast and seamless booking.</p>
                    </div>
                </div>
            </div>

            <div class="form-side">
                <div class="form-content">
                    <div class="top-icon">📅</div>

                    <h2 class="brand-title">Smart Booking System</h2>
                    <p class="brand-subtitle">Clinic / Salon / Advisor</p>

                    <h1>Create Account</h1>
                    <p class="description">
                        Register to manage your appointments and services with ease.
                    </p>

                    <% if (typeof message !== "undefined" && message) { %>
                        <div class="message <%= messageType === 'error' ? 'error' : 'success' %>">
                            <%= message %>
                        </div>
                    <% } %>

                    <form action="/views/register" method="POST">
                        <div class="field">
                            <label for="user_name">Full Name</label>
                            <div class="input-box">
                                <span class="input-icon">👤</span>
                                <input
                                    type="text"
                                    id="user_fullname"
                                    name="user_fullname"
                                    placeholder="Enter your full name"
                                    autocomplete="name"
                                    required
                                />
                            </div>
                        </div>

                        <div class="field">
                            <label for="user_email">Email</label>
                            <div class="input-box">
                                <span class="input-icon">✉️</span>
                                <input
                                    type="email"
                                    id="user_email"
                                    name="user_email"
                                    placeholder="Enter your email address"
                                    autocomplete="email"
                                    required
                                />
                            </div>
                        </div>

                        <div class="field">
                            <label for="user_phone">Phone</label>
                            <div class="input-box">
                                <span class="input-icon">📞</span>
                                <input
                                    type="tel"
                                    id="user_phone"
                                    name="user_phone"
                                    placeholder="Enter your phone number"
                                    autocomplete="tel"
                                />
                            </div>
                        </div>

                        <div class="field">
                            <label for="user_password">Password</label>
                            <div class="input-box">
                                <span class="input-icon">🔒</span>

                                <input
                                    type="password"
                                    id="user_password"
                                    name="user_password"
                                    placeholder="Create a password"
                                    autocomplete="new-password"
                                    required
                                />

                                <button
                                    type="button"
                                    class="password-toggle"
                                    id="togglePassword"
                                    aria-label="Show password"
                                >
                                    👁️
                                </button>
                            </div>
                        </div>

                        <div class="field">
                            <label for="confirm_password">Confirm Password</label>
                            <div class="input-box">
                                <span class="input-icon">🔒</span>

                                <input
                                    type="password"
                                    id="confirm_password"
                                    name="confirm_password"
                                    placeholder="Confirm your password"
                                    autocomplete="new-password"
                                    required
                                />

                                <button
                                    type="button"
                                    class="password-toggle"
                                    id="toggleConfirmPassword"
                                    aria-label="Show confirm password"
                                >
                                    👁️
                                </button>
                            </div>
                        </div>

                        <button class="register-button" type="submit">
                            Register →
                        </button>
                    </form>

                   <p class="login-text">
                         Already have an account?
                         <a href="/views/login">login</a>
                   </p>
                   <div class="bottom-divider">
                        <span class="heart">❤️</span>
                   </div>
                     <p class="secure-note">
                        Built to help you deliver exceptional care and seamless appointment experiences.
                     </p>
                </div>
            </div>
        </section>
    </main>

    <script>
        const passwordInput = document.getElementById("user_password");
        const togglePassword = document.getElementById("togglePassword");

        togglePassword.addEventListener("click", function () {
            const isPasswordHidden = passwordInput.type === "password";

            passwordInput.type = isPasswordHidden ? "text" : "password";
            togglePassword.textContent = isPasswordHidden ? "🙈" : "👁️";
            togglePassword.setAttribute(
                "aria-label",
                isPasswordHidden ? "Hide password" : "Show password"
            );
        });

        const confirmPasswordInput = document.getElementById("confirm_password");
        const toggleConfirmPassword = document.getElementById("toggleConfirmPassword");

        toggleConfirmPassword.addEventListener("click", function () {
            const isPasswordHidden = confirmPasswordInput.type === "password";

            confirmPasswordInput.type = isPasswordHidden ? "text" : "password";
            toggleConfirmPassword.textContent = isPasswordHidden ? "🙈" : "👁️";
            toggleConfirmPassword.setAttribute(
                "aria-label",
                isPasswordHidden ? "Hide confirm password" : "Show confirm password"
            );
        });
    </script>
</body>
</html>