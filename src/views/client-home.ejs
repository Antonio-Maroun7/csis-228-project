<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title><%= typeof title !== "undefined" ? title : "Client Home" %></title>

    <link rel="stylesheet" href="/styles/dashboard.css" />
    <link rel="stylesheet" href="/styles/client-home.css" />
</head>

<body class="client-home-body">
    <%
        const safeRole =
            typeof role !== "undefined" && role
                ? role
                : "client";

        const safeActivePage =
            typeof activePage !== "undefined" && activePage
                ? activePage
                : "client-home";

        const safeFirstName =
            typeof firstName !== "undefined" && firstName
                ? firstName
                : "Client";

        const safeBreadcrumbMain =
            typeof breadcrumbMain !== "undefined" && breadcrumbMain
                ? breadcrumbMain
                : "Home";

        const safeBreadcrumbSub =
            typeof breadcrumbSub !== "undefined" && breadcrumbSub
                ? breadcrumbSub
                : "Categories";

        const categoryList =
            typeof categories !== "undefined" && Array.isArray(categories)
                ? categories
                : [];

        const pageStats =
            typeof stats !== "undefined" && stats
                ? stats
                : {
                    availableCategories: categoryList.length,
                    upcomingAppointments: 0,
                    favoriteServices: 0,
                };
    %>

    <main class="dashboard-page">
        <section class="dashboard">
            <%- include("./partials/dashboard-sidebar", {
                role: safeRole,
                activePage: safeActivePage
            }) %>

            <section class="dashboard-main">
                <%- include("./partials/dashboard-topbar", {
                    breadcrumbMain: safeBreadcrumbMain,
                    breadcrumbSub: safeBreadcrumbSub,
                    firstName: safeFirstName,
                    role: safeRole,
                    showNotification: false,
                    searchPlaceholder: "Search services, categories..."
                }) %>

                <div class="dashboard-content">
                    <% if (typeof message !== "undefined" && message && messageType === "error") { %>
                        <div class="ch-message error"><%= message %></div>
                    <% } %>

                    <!-- ── Top row: stat cards (left) + promo card (right) ── -->
                    <div class="ch-header">
                        <div class="ch-left">
                            <!-- Stat cards -->
                            <div class="ch-stats">
                                <article class="ch-stat-card card">
                                    <div class="ch-stat-icon ch-icon-teal">▦</div>
                                    <div class="ch-stat-body">
                                        <strong><%= pageStats.availableCategories %></strong>
                                        <span>Available Categories</span>
                                        <small>Explore a wide range</small>
                                    </div>
                                </article>

                                <article class="ch-stat-card card">
                                    <div class="ch-stat-icon ch-icon-blue">📅</div>
                                    <div class="ch-stat-body">
                                        <strong><%= pageStats.upcomingAppointments %></strong>
                                        <span>Upcoming Appointments</span>
                                        <small>Next one coming soon</small>
                                    </div>
                                </article>

                                <article class="ch-stat-card card">
                                    <div class="ch-stat-icon ch-icon-pink">♡</div>
                                    <div class="ch-stat-body">
                                        <strong><%= pageStats.favoriteServices %></strong>
                                        <span>Favorite Services</span>
                                        <small>Your go-to services</small>
                                    </div>
                                </article>

                                <% if (typeof weather !== 'undefined' && weather) { %>
                                <article class="ch-stat-card ch-weather-card card">
                                    <div class="ch-stat-icon ch-icon-weather"><%= weather.icon %></div>
                                    <div class="ch-stat-body">
                                        <strong><%= weather.temp %>°C</strong>
                                        <span><%= weather.label %></span>
                                        <small>Wind <%= weather.wind %> km/h</small>
                                    </div>
                                </article>
                                <% } %>
                            </div>

                            <!-- Browse title -->
                            <div class="ch-browse-title">
                                <h2>Browse Categories</h2>
                                <p>Select a category to explore services and book an appointment.</p>
                            </div>
                        </div>

                        <!-- Promo card -->
                        <article class="ch-promo-card card">
                            <img
                                src="/images/client-wellness-banner.png"
                                alt="Wellness booking banner"
                                class="ch-promo-banner"
                            />
                        </article>
                    </div>

                    <!-- ── Category grid ── -->
                    <% if (!categoryList.length) { %>
                        <section class="ch-empty card">
                            <h3>No categories available</h3>
                            <p>There are no active categories in the database right now.</p>
                        </section>
                    <% } else { %>
                        <section class="ch-grid" id="categoryGrid">
                            <% categoryList.forEach(function(category) { %>
                                <article
                                    class="ch-cat-card card <%= category.featured ? 'ch-featured' : '' %>"
                                    data-category-card
                                    data-search-text="<%= `${category.name || ''} ${category.description || ''}`.toLowerCase() %>"
                                >
                                    <div class="ch-cat-icon">
                                        <%= category.icon || "▦" %>
                                    </div>

                                    <h3><%= category.name %></h3>

                                    <p>
                                        <%= category.description || "Explore available services and book your appointment" %>
                                    </p>

                                    <div class="ch-badge">
                                        <%= category.servicesCount || 0 %> Services
                                    </div>

                                    <a
                                        class="outline-button"
                                        href="/views/services-by-category/<%= category.id %>"
                                    >
                                        View Services
                                    </a>
                                </article>
                            <% }) %>
                        </section>

                        <section
                            class="ch-empty card ch-search-empty"
                            id="searchEmptyState"
                            hidden
                        >
                            <h3>No matching categories</h3>
                            <p>Try searching with another category name or description.</p>
                        </section>
                    <% } %>
                </div>
            </section>
        </section>
    </main>

    <script src="/scripts/client/client-home.js"></script>
</body>
</html>