<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Smart Booking</title>
    <link rel="stylesheet" href="/styles/dashboard.css" />
    <link rel="stylesheet" href="/styles/admin.css" />
    <link rel="stylesheet" href="/styles/admin-appointments.css" />
</head>
<body class="admin-appointments-body">
<div class="dashboard-page">
<div class="dashboard">

    <%- include('partials/dashboard-sidebar', { role, activePage }) %>

    <main class="dashboard-main">
        <%- include('partials/dashboard-topbar', {
            breadcrumbMain: 'Home',
            breadcrumbSub: 'Appointments',
            firstName,
            role,
            searchPlaceholder: 'Search appointments...',
            showNotification: false
        }) %>

        <div class="dashboard-content">

            <% if (locals.message) { %>
            <div class="admin-feedback <%= messageType %>">
                <span><%= message %></span>
                <button class="aa-feedback-close" type="button" onclick="this.parentElement.remove()">&#x2715;</button>
            </div>
            <% } %>

            <!-- Page Header -->
            <div class="aa-page-header">
                <div>
                    <h2 class="aa-page-title">Appointments</h2>
                    <p class="aa-page-subtitle">View, manage, and track all customer appointments.</p>
                </div>
            </div>

            <!-- Main two-column layout -->
            <div class="aa-main-layout">

                <!-- ── Left: Table Panel ───────────────────────────────────── -->
                <div class="aa-table-panel">
                    <div class="aa-card">
                        <!-- Card header -->
                        <div class="aa-card-header">
                            <span class="aa-card-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                                </svg>
                                All Appointments
                            </span>
                        </div>

                        <!-- Table scroll -->
                        <div class="aa-table-scroll" id="aaTableScroll">
                            <table class="aa-table" id="aaTable">
                                <thead>
                                    <tr>
                                        <th>Appointment ID</th>
                                        <th>Customer</th>
                                        <th>Service</th>
                                        <th>Staff</th>
                                        <th>Date &amp; Time</th>
                                        <th>Status</th>
                                        <th>Payment</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="aaTableBody">
                                    <!-- Rendered by JS -->
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination footer -->
                        <div class="aa-pagination-bar" id="aaPaginationBar">
                            <span class="aa-pag-info" id="aaPagInfo">Showing 0 to 0 of 0 entries</span>
                            <div class="aa-pag-btns" id="aaPagBtns"></div>
                        </div>
                    </div>
                </div><!-- /.aa-table-panel -->

                <!-- ── Right: Filters + Summary ───────────────────────────── -->
                <div class="aa-right-panel">

                    <!-- Filters Card -->
                    <div class="aa-filters-card">
                        <h3 class="aa-filters-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
                            </svg>
                            Filters
                        </h3>

                        <div class="aa-filter-group">
                            <label class="aa-filter-label">Status</label>
                            <select id="aaFilterStatus" class="aa-filter-select">
                                <option value="">All Statuses</option>
                                <option value="confirmed">Confirmed</option>
                                <option value="pending">Pending</option>
                                <option value="completed">Completed</option>
                                <option value="cancelled">Cancelled</option>
                                <option value="no_show">No Show</option>
                            </select>
                        </div>

                        <div class="aa-filter-group">
                            <label class="aa-filter-label">Payment Status</label>
                            <select id="aaFilterPayment" class="aa-filter-select">
                                <option value="">All Payment Statuses</option>
                                <option value="paid">Paid</option>
                                <option value="unpaid">Unpaid</option>
                                <option value="refunded">Refunded</option>
                            </select>
                        </div>

                        <div class="aa-filter-group">
                            <label class="aa-filter-label">Service</label>
                            <select id="aaFilterService" class="aa-filter-select">
                                <option value="">All Services</option>
                                <% (allServices || []).forEach(function(svc) { %>
                                <option value="<%= svc.id %>"><%= svc.name %></option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="aa-filter-group">
                            <label class="aa-filter-label">Staff</label>
                            <select id="aaFilterStaff" class="aa-filter-select">
                                <option value="">All Staff</option>
                                <% (staffUsers || []).forEach(function(su) { %>
                                <option value="<%= su.id %>"><%= su.fullname %></option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="aa-filter-group aa-filter-date-row">
                            <label class="aa-filter-label">Date Range</label>
                            <div class="aa-filter-date-pair">
                                <input type="date" id="aaFilterDateFrom" class="aa-filter-date" placeholder="From" />
                                <input type="date" id="aaFilterDateTo" class="aa-filter-date" placeholder="To" />
                            </div>
                        </div>

                        <button type="button" class="aa-btn-apply" id="aaApplyFilters">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
                            </svg>
                            Apply Filters
                        </button>
                        <button type="button" class="aa-btn-reset" id="aaResetFilters">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/>
                            </svg>
                            Reset Filters
                        </button>
                    </div>

                    <!-- Summary Card -->
                    <div class="aa-summary-card">
                        <h3 class="aa-summary-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                            </svg>
                            Appointment Summary
                        </h3>

                        <div class="aa-summary-row">
                            <span class="aa-summary-label aa-summary-total">Total Appointments</span>
                            <span class="aa-summary-count aa-summary-total" id="aaSumTotal"><%= (summary || {}).total || 0 %></span>
                        </div>
                        <hr class="aa-summary-divider" />
                        <div class="aa-summary-row">
                            <span class="aa-summary-label">
                                <span class="aa-dot aa-dot-confirmed"></span>Confirmed
                            </span>
                            <span class="aa-summary-count" id="aaSumConfirmed"><%= (summary || {}).confirmed || 0 %></span>
                        </div>
                        <div class="aa-summary-row">
                            <span class="aa-summary-label">
                                <span class="aa-dot aa-dot-pending"></span>Pending
                            </span>
                            <span class="aa-summary-count" id="aaSumPending"><%= (summary || {}).pending || 0 %></span>
                        </div>
                        <div class="aa-summary-row">
                            <span class="aa-summary-label">
                                <span class="aa-dot aa-dot-completed"></span>Completed
                            </span>
                            <span class="aa-summary-count" id="aaSumCompleted"><%= (summary || {}).completed || 0 %></span>
                        </div>
                        <div class="aa-summary-row">
                            <span class="aa-summary-label">
                                <span class="aa-dot aa-dot-cancelled"></span>Cancelled
                            </span>
                            <span class="aa-summary-count" id="aaSumCancelled"><%= (summary || {}).cancelled || 0 %></span>
                        </div>
                    </div>

                </div><!-- /.aa-right-panel -->

            </div><!-- /.aa-main-layout -->

        </div><!-- /.dashboard-content -->
    </main>

</div>
</div>

<!-- Detail Modal -->
<div class="aa-modal-overlay" id="aaDetailModal" role="dialog" aria-modal="true" aria-labelledby="aaModalTitle">
    <div class="aa-modal">
        <div class="aa-modal-header">
            <h3 id="aaModalTitle">Appointment Details</h3>
            <button class="aa-modal-close" id="aaModalCloseBtn" type="button" aria-label="Close">&times;</button>
        </div>
        <div class="aa-modal-body" id="aaModalBody">
            <!-- filled by JS -->
        </div>
    </div>
</div>

<!-- JS Globals -->
<script>
var AA_APPOINTMENTS = <%- JSON.stringify(appointments || []) %>;
var AA_STAFF_LIST   = <%- JSON.stringify(staffUsers || []) %>;
</script>
<script src="/scripts/admin-appointments.js"></script>

</body>
</html>
</html>
