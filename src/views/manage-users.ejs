<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Smart Booking</title>
    <link rel="stylesheet" href="/styles/dashboard.css" />
    <link rel="stylesheet" href="/styles/admin.css" />
    <link rel="stylesheet" href="/styles/manage-users.css" />
</head>
<body class="manage-users-body">
<div class="dashboard-page">
<div class="dashboard">

    <%- include('partials/dashboard-sidebar', { role, activePage }) %>

    <main class="dashboard-main">
        <%- include('partials/dashboard-topbar', {
            breadcrumbMain: 'Home',
            breadcrumbSub: 'Manage Users',
            firstName,
            role,
            showNotification: false,
            showTopbarSearch: false
        }) %>

        <div class="dashboard-content">

            <% if (message) { %>
            <div class="admin-feedback <%= messageType %>">
                <span><%= message %></span>
                <button class="mu-feedback-close" type="button" onclick="this.parentElement.remove()">✕</button>
            </div>
            <% } %>

            <!-- Page Header -->
            <div class="mu-page-header">
                <div>
                    <h2 class="mu-page-title">Manage Users</h2>
                    <p class="mu-page-subtitle">All registered users in the system</p>
                </div>
                <button class="mu-btn-add" type="button" id="openAddModal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.03 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                        <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5z"/>
                    </svg>
                    Add New User
                </button>
            </div>

            <!-- Table Card -->
            <div class="mu-card">
                <!-- Toolbar -->
                <div class="mu-toolbar">
                    <div class="mu-show-entries">
                        <span>Show</span>
                        <select id="muEntriesSelect" class="mu-entries-select">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                        <span>entries</span>
                    </div>
                    <div class="mu-search-wrap">
                        <svg class="mu-search-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input type="text" id="muSearchInput" class="mu-search-input" placeholder="Search..." />
                    </div>
                </div>

                <!-- Table -->
                <div class="mu-table-outer">
                    <table class="mu-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>USER</th>
                                <th>EMAIL</th>
                                <th>PHONE</th>
                                <th>ROLE</th>
                                <th>STATUS</th>
                                <th>ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody id="muTableBody">
                            <!-- Populated by manage-users.js -->
                        </tbody>
                    </table>
                </div>

                <!-- Footer -->
                <div class="mu-table-footer">
                    <span id="muShowingText" class="mu-showing">Showing 0 to 0 of 0 entries</span>
                    <div class="mu-pagination" id="muPagination"></div>
                </div>
            </div>

        </div><!-- /.dashboard-content -->
    </main>

</div>
</div>

<!-- ═══════════════════════════════════════════════
     ADD USER MODAL
═══════════════════════════════════════════════ -->
<div class="mu-overlay" id="addModalOverlay">
    <div class="mu-modal">
        <div class="mu-modal-head">
            <h3 class="mu-modal-title">Add New User</h3>
            <button class="mu-modal-close" type="button" data-close="addModalOverlay">✕</button>
        </div>
        <form class="mu-form" method="POST" action="/views/manage-users/create">
            <div class="mu-form-row">
                <div class="mu-form-group">
                    <label class="mu-label">Full Name <span class="mu-req">*</span></label>
                    <input type="text" name="user_fullname" class="mu-input" placeholder="e.g. John Doe" required />
                </div>
                <div class="mu-form-group">
                    <label class="mu-label">Email Address <span class="mu-req">*</span></label>
                    <input type="email" name="user_email" class="mu-input" placeholder="email@example.com" required />
                </div>
            </div>
            <div class="mu-form-row">
                <div class="mu-form-group">
                    <label class="mu-label">Phone</label>
                    <input type="text" name="user_phone" class="mu-input" placeholder="Optional" />
                </div>
                <div class="mu-form-group">
                    <label class="mu-label">Password <span class="mu-req">*</span></label>
                    <input type="password" name="user_password" class="mu-input" placeholder="Min 6 characters" required minlength="6" />
                </div>
            </div>
            <div class="mu-form-row">
                <div class="mu-form-group">
                    <label class="mu-label">Role</label>
                    <select name="user_role" class="mu-input">
                        <option value="client">Client</option>
                        <option value="staff">Staff</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                <div class="mu-form-group">
                    <label class="mu-label">Status</label>
                    <select name="user_is_active" class="mu-input">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
            </div>
            <div class="mu-form-actions">
                <button type="button" class="mu-btn-cancel" data-close="addModalOverlay">Cancel</button>
                <button type="submit" class="mu-btn-submit">Create User</button>
            </div>
        </form>
    </div>
</div>

<!-- ═══════════════════════════════════════════════
     EDIT USER MODAL
═══════════════════════════════════════════════ -->
<div class="mu-overlay" id="editModalOverlay">
    <div class="mu-modal">
        <div class="mu-modal-head">
            <h3 class="mu-modal-title">Edit User</h3>
            <button class="mu-modal-close" type="button" data-close="editModalOverlay">✕</button>
        </div>
        <form class="mu-form" method="POST" id="editUserForm" action="#">
            <div class="mu-form-row">
                <div class="mu-form-group">
                    <label class="mu-label">Full Name <span class="mu-req">*</span></label>
                    <input type="text" name="user_fullname" id="editFullname" class="mu-input" required />
                </div>
                <div class="mu-form-group">
                    <label class="mu-label">Email Address <span class="mu-req">*</span></label>
                    <input type="email" name="user_email" id="editEmail" class="mu-input" required />
                </div>
            </div>
            <div class="mu-form-row">
                <div class="mu-form-group">
                    <label class="mu-label">Phone</label>
                    <input type="text" name="user_phone" id="editPhone" class="mu-input" />
                </div>
                <div class="mu-form-group">
                    <label class="mu-label">Role</label>
                    <select name="user_role" id="editRole" class="mu-input">
                        <option value="client">Client</option>
                        <option value="staff">Staff</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
            </div>
            <div class="mu-form-row">
                <div class="mu-form-group">
                    <label class="mu-label">Status</label>
                    <select name="user_is_active" id="editStatus" class="mu-input">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
                <div class="mu-form-group"><!-- spacer --></div>
            </div>
            <div class="mu-form-actions">
                <button type="button" class="mu-btn-cancel" data-close="editModalOverlay">Cancel</button>
                <button type="submit" class="mu-btn-submit">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- ═══════════════════════════════════════════════
     DELETE CONFIRMATION MODAL
═══════════════════════════════════════════════ -->
<div class="mu-overlay" id="deleteModalOverlay">
    <div class="mu-modal mu-modal-sm">
        <div class="mu-modal-head">
            <h3 class="mu-modal-title">Delete User</h3>
            <button class="mu-modal-close" type="button" data-close="deleteModalOverlay">✕</button>
        </div>
        <div class="mu-del-body">
            <div class="mu-del-icon">🗑️</div>
            <p class="mu-del-text">Are you sure you want to delete <strong id="deleteUserName"></strong>?</p>
            <p class="mu-del-sub">This action cannot be undone.</p>
        </div>
        <form method="POST" id="deleteUserForm" action="#">
            <div class="mu-form-actions" style="padding: 0 24px 24px;">
                <button type="button" class="mu-btn-cancel" data-close="deleteModalOverlay">Cancel</button>
                <button type="submit" class="mu-btn-danger">Delete</button>
            </div>
        </form>
    </div>
</div>

<!-- Inject users data for client-side JS -->
<script>
/* global ALL_USERS */
const ALL_USERS = <%- JSON.stringify(users.map(function(u) {
    return {
        id: u.id,
        fullname: u.fullname || '',
        email: u.email || '',
        phone: u.phone || '',
        role: u.role || 'client',
        is_active: u.is_active !== false
    };
})).replace(/<\//g, '<\\/') %>;
</script>
<script src="/scripts/manage-users.js"></script>
</body>
</html>
